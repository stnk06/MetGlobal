<Window x:Class="MetGlobal.Views.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        Title="Карточка продукции" Width="700" Height="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/SharedResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Padding="25" Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="*"/>
                <!-- Форма -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Text="Редактирование товара" 
                       Grid.Row="0"
                       FontSize="24" FontWeight="Light" 
                       Foreground="{DynamicResource MahApps.Brushes.Accent}" 
                       Margin="0,0,0,25"/>

            <!-- Основная форма в две колонки -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <!-- Разделитель -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ЛЕВАЯ КОЛОНКА: Основные данные -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ОСНОВНАЯ ИНФОРМАЦИЯ" FontWeight="Bold" Foreground="{StaticResource BrushLightGray}" Margin="0,0,0,10"/>

                    <!-- Артикул -->
                    <Label Content="Артикул *" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PrefixComboBox" 
                                  Style="{DynamicResource MahApps.Styles.ComboBox}"
                                  mah:TextBoxHelper.Watermark="Тип"
                                  ToolTip="Выберите тип материала"/>
                        <TextBox x:Name="SuffixTextBox" Grid.Column="1" Margin="5,0,0,0"
                                 Style="{DynamicResource MahApps.Styles.TextBox}"
                                 mah:TextBoxHelper.Watermark="Номер (0000)"
                                 ToolTip="Введите номер"/>
                    </Grid>

                    <!-- Наименование -->
                    <Label Content="Наименование *" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource MahApps.Styles.TextBox}"
                             mah:TextBoxHelper.Watermark="Например: Труба стальная бесшовная"
                             mah:TextBoxHelper.ClearTextButton="True"
                             Margin="0,0,0,15"/>

                    <!-- Категория -->
                    <Label Content="Категория *" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CategoryComboBox"
                              Style="{DynamicResource MahApps.Styles.ComboBox}"
                              DisplayMemberPath="CategoryName"
                              SelectedValuePath="CategoryID"
                              SelectedValue="{Binding CategoryID}"
                              mah:TextBoxHelper.Watermark="Выберите категорию"
                              Margin="0,0,0,15"/>

                    <!-- Поставщик -->
                    <Label Content="Поставщик *" FontWeight="SemiBold"/>
                    <ComboBox x:Name="SupplierComboBox"
                              Style="{DynamicResource MahApps.Styles.ComboBox}"
                              DisplayMemberPath="SupplierName"
                              SelectedValuePath="SupplierID"
                              SelectedValue="{Binding SupplierID}"
                              mah:TextBoxHelper.Watermark="Выберите поставщика"
                              Margin="0,0,0,5"/>
                </StackPanel>

                <!-- ПРАВАЯ КОЛОНКА: Характеристики -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="ХАРАКТЕРИСТИКИ И ЦЕНА" FontWeight="Bold" Foreground="{StaticResource BrushLightGray}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Цена -->
                        <StackPanel Grid.Column="0">
                            <Label Content="Цена (руб.) *" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                                     Style="{DynamicResource MahApps.Styles.TextBox}"
                                     mah:TextBoxHelper.Watermark="0.00"/>
                        </StackPanel>

                        <!-- Ед. изм. -->
                        <StackPanel Grid.Column="2">
                            <Label Content="Ед. изм. *" FontWeight="SemiBold"/>
                            <ComboBox x:Name="UnitComboBox"
                                      Style="{DynamicResource MahApps.Styles.ComboBox}"
                                      IsEditable="False"
                                      SelectedItem="{Binding Unit}"
                                      mah:TextBoxHelper.Watermark="Выбрать..."/>
                        </StackPanel>
                    </Grid>

                    <!-- ГОСТ -->
                    <Label Content="ГОСТ" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding GOST, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource MahApps.Styles.TextBox}"
                             PreviewKeyDown="GostTextBox_PreviewKeyDown"
                             TextChanged="GostTextBox_TextChanged"
                             mah:TextBoxHelper.Watermark="ГОСТ ..."
                             Margin="0,0,0,15"/>

                    <!-- Плотность -->
                    <Label Content="Плотность (кг/м³)" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Density, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" 
                             Style="{DynamicResource MahApps.Styles.TextBox}"
                             mah:TextBoxHelper.Watermark="Необязательно"
                             Margin="0,0,0,15"/>
                </StackPanel>
            </Grid>

            <!-- Кнопки действий -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Сохранить" 
                        IsDefault="True" 
                        Click="SaveButton_Click" 
                        Width="120" Height="35" FontSize="14" FontWeight="Bold"/>

                <Button Content="Отмена" 
                        IsCancel="True"
                        Width="100" Height="35" FontSize="14" Margin="15,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>