<UserControl x:Class="MetGlobal.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Клиентская база" Style="{DynamicResource MahApps.Styles.TextBlock.Title}" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox mah:TextBoxHelper.Watermark="Поиск по названию или контакту..."
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0,0,10,0" Style="{DynamicResource MahApps.Styles.TextBox}"/>
            <Button Content="Найти" Command="{Binding SearchCommand}"/>
        </StackPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}"
                  Style="{DynamicResource MahApps.Styles.DataGrid.Azure}" CanUserAddRows="False" IsReadOnly="True" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название компании" Binding="{Binding CompanyName}" Width="2*"/>
                <DataGridTextColumn Header="Контактное лицо" Binding="{Binding ContactName}" Width="1.5*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
                <DataGridTextColumn Header="Эл. почта" Binding="{Binding Email}" Width="1.5*"/>
                <DataGridTextColumn Header="Юридический адрес" Binding="{Binding LegalAddress}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Добавить" Command="{Binding AddCommand}"  Margin="0,0,5,0"/>
                <Button Content="Изменить" Command="{Binding EditCommand}" Margin="0,0,5,0"/>
                <Button Content="Удалить" Command="{Binding DeleteCommand}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Экспорт в PDF" Command="{Binding ExportToPdfCommand}" Margin="0,0,5,0"/>
                <Button Content="Экспорт в Excel" Command="{Binding ExportToExcelCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>