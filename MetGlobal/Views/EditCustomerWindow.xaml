<Window x:Class="MetGlobal.Views.EditCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        Title="Карточка клиента" Width="700" Height="480"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/SharedResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Padding="25" Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Редактирование клиента" 
                       Grid.Row="0"
                       FontSize="24" FontWeight="Light" 
                       Foreground="{DynamicResource MahApps.Brushes.Accent}" 
                       Margin="0,0,0,25"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ЛЕВАЯ КОЛОНКА -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="КОМПАНИЯ И КОНТАКТЫ" FontWeight="Bold" Foreground="{StaticResource BrushLightGray}" Margin="0,0,0,10"/>

                    <Label Content="Название компании *" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CompTypeComboBox" 
                                  Style="{DynamicResource MahApps.Styles.ComboBox}"
                                  mah:TextBoxHelper.Watermark="Тип"/>

                        <TextBox x:Name="CompNameTextBox" Grid.Column="1" Margin="5,0,0,0"
                                 Style="{DynamicResource MahApps.Styles.TextBox}"
                                 mah:TextBoxHelper.Watermark="Название"
                                 PreviewTextInput="BlockLatinInput"/>
                    </Grid>

                    <!-- ВАЖНО: Привязка событий для контактного лица -->
                    <Label Content="Контактное лицо *" FontWeight="SemiBold"/>
                    <TextBox x:Name="ContactNameTextBox"
                             Text="{Binding ContactName, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource MahApps.Styles.TextBox}"
                             mah:TextBoxHelper.Watermark="Фамилия И.О."
                             ToolTip="Пример: Иванов И.И."
                             PreviewTextInput="ContactName_PreviewTextInput"
                             TextChanged="ContactNameTextBox_TextChanged"
                             Margin="0,0,0,15"/>

                    <!-- ВАЖНО: Привязка событий для телефона -->
                    <Label Content="Телефон *" FontWeight="SemiBold"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ComboBox x:Name="PhoneMaskComboBox" Grid.Row="0" Margin="0,0,0,5"
                                  Style="{DynamicResource MahApps.Styles.ComboBox}"
                                  FontSize="12"
                                  SelectionChanged="PhoneMaskComboBox_SelectionChanged"/>

                        <TextBox x:Name="PhoneTextBox" Grid.Row="1"
                                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{DynamicResource MahApps.Styles.TextBox}"
                                 mah:TextBoxHelper.Watermark="+7 ..."
                                 PreviewTextInput="BlockNonDigits"
                                 TextChanged="PhoneTextBox_TextChanged"/>
                    </Grid>
                </StackPanel>

                <!-- ПРАВАЯ КОЛОНКА -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="РЕКВИЗИТЫ И АДРЕС" FontWeight="Bold" Foreground="{StaticResource BrushLightGray}" Margin="0,0,0,10"/>

                    <Label Content="Email" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource MahApps.Styles.TextBox}"
                             Margin="0,0,0,15"/>

                    <Label Content="Юридический адрес" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding LegalAddress, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{DynamicResource MahApps.Styles.TextBox}"
                             TextWrapping="Wrap"
                             Height="80"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,15"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Сохранить" IsDefault="True" Click="SaveButton_Click" 
                         Width="120" Height="35"/>
                <Button Content="Отмена" IsCancel="True" Click="SaveButton_Click"
                         Width="100" Height="35" Margin="15,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>