<Window x:Class="MetGlobal.Views.EditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Редактирование заказа" Width="800" Height="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка заказа -->
        <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Клиент:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AllCustomers}" DisplayMemberPath="CompanyName"
                          SelectedValuePath="CustomerID" SelectedValue="{Binding CurrentOrder.CustomerID}" Margin="5"/>

                <Label Grid.Row="0" Grid.Column="2" Content="Статус:" VerticalAlignment="Center" Margin="5"/>
                <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding AllStatuses}" 
                          SelectedItem="{Binding CurrentOrder.Status}" Margin="5"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Дата заказа:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding CurrentOrder.OrderDate}" Margin="5"/>
            </Grid>
        </Border>

        <!-- Состав заказа -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding OrderDetails}" Margin="0,10"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="3*"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="*"/>
                <DataGridTextColumn Header="Цена за ед." Binding="{Binding UnitPrice, StringFormat=C, ConverterCulture=ru-RU}" Width="*"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat=C, ConverterCulture=ru-RU}" Width="*"/>
                <DataGridTemplateColumn Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Удалить" Command="{Binding DataContext.RemoveDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" Padding="5,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель добавления -->
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" Padding="5">
            <StackPanel Orientation="Horizontal">
                <Label Content="Добавить товар:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding AllProducts}" SelectedItem="{Binding SelectedProductToAdd}" 
                          DisplayMemberPath="ProductName" Width="300" Margin="5,0"/>
                <Label Content="Кол-во:" VerticalAlignment="Center"/>
                <TextBox Text="{Binding QuantityToAdd}" Width="50" Margin="5,0"/>
                <Button Content="Добавить в заказ" Command="{Binding AddDetailCommand}" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Итоги и кнопки -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <TextBlock Text="{Binding CurrentOrder.TotalAmount, StringFormat='Итоговая сумма: {0:C}', ConverterCulture=ru-RU}"
                       FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" IsDefault="True" Click="SaveButton_Click" Margin="0,0,10,0"/>
                <Button Content="Отмена" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
